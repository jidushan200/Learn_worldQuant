# ══════════════════════════════════════════════
#  AI 提供商选择: packy / poe / openai / anthropic
# ══════════════════════════════════════════════
AI_PROVIDER=packy

# ── PackyAPI（推荐，一个 key 调所有模型）──
#  获取: https://www.packyapi.com → 控制台 → 令牌管理 → 创建令牌
#  模型广场: https://www.packyapi.com → 模型广场 查看全部可用模型
#
#  ── OpenAI GPT 系列（按性价比排序）──
#    gpt-5.4-mini              输入$0.375/M  输出$2.25/M   分组:codex   ← 最便宜，适合大量跑测试
#    gpt-5.2                   输入$0.875/M  输出$7/M      分组:codex
#    gpt-5.2-low/medium/high   输入$0.875/M  输出$7/M      分组:codex/cxtocc
#    gpt-5.3-codex             输入$0.875/M  输出$7/M      分组:codex
#    gpt-5.4                   输入$1.25/M   输出$7.5/M    分组:codex   ← 当前使用，主力模型
#    gpt-5.4-low/medium        输入$1.25/M   输出$7.5/M    分组:cxtocc
#    gpt-5.4-high              输入$1.25/M   输出$7.5/M    分组:codex
#    gpt-5.5                   输入$2.5/M    输出$15/M     分组:codex   ← 最强但最贵
#
#  ── Anthropic Claude 系列（按性价比排序）──
#    claude-haiku-4-5-20251001   输入$0.8/M  输出$4/M    分组:cc-sale  ← 最便宜，适合大量跑测试
#    claude-sonnet-4-6           输入$2.4/M  输出$12/M   分组:cc-sale  ← 推荐，性价比最高
#    claude-opus-4-6             输入$4/M    输出$20/M   分组:cc-sale
#    claude-sonnet-4-5-20250929  输入$7.5/M  输出$37.5/M 分组:cc
#    claude-opus-4-5-20251101    输入$12.5/M 输出$62.5/M 分组:cc
#    claude-opus-4-7             输入$12.5/M 输出$62.5/M 分组:cc       ← 最新旗舰，贵
#    claude-opus-4-1-20250805    输入$37.5/M 输出$187.5/M 分组:cc      ← 最贵
#
#  注意：令牌分组必须匹配！不同模型属于不同分组
#
PACKY_API_KEY=sk-XKwdMQCXKJmke9CjHjqDpJG3v0qaAj0Mjp1UgF2FOsfNz1yy
PACKY_MODEL=gpt-5.5
PACKY_BASE_URL=https://www.packyapi.com/v1

